options(
knitr.table.format = "html",
scipen = 999
)
library(knitr)
# Datos
x <- 0:6
fx <- c(0.06, 0.13, 0.20, 0.28, 0.25, 0.05, 0.03)
Fx <- cumsum(fx)
# Crear tabla
tabla <- data.frame(
x = x,
fx = fx,
Fx = Fx
)
# Mostrar tabla
kable(tabla, digits = 2, caption = "Tabla de x, f(x), F(x)")
library(knitr)
library(kableExtra)
library(dplyr)
# Datos
x <- 0:6
fx <- c(0.06, 0.13, 0.20, 0.28, 0.25, 0.05, 0.03)
Fx <- cumsum(fx)
# Crear tabla
tabla <- data.frame(
x = as.character(x),
fx = fx,
Fx = Fx
)
# Agregar fila de sumatoria
tabla_final <- tabla %>%
bind_rows(
data.frame(
x = "Σ",
fx = sum(fx),
Fx = NA_real_
)
)
# Mostrar tabla con estilo
kable(
tabla_final,
digits = 2,
align = "ccc",
caption = "Tabla de $x$, $f(x)$, $F(x)$",
na = ""
) %>%
kable_styling(
full_width = FALSE,
bootstrap_options = c("striped", "hover", "condensed")
) %>%
row_spec(0, bold = TRUE, background = "#D9EAF7") %>%
row_spec(nrow(tabla_final), bold = TRUE, background = "#FADBD8")
kable(
tabla_dec,
digits = 2,
align = "ccc",
caption = "Tabla en decimales (2 cifras)",
na = ""
) %>%
kable_styling(
full_width = FALSE,
bootstrap_options = c("striped", "hover")
) %>%
row_spec(0, bold = TRUE, background = "#D9EAF7") %>%
row_spec(nrow(tabla_dec), bold = TRUE, background = "#FADBD8")
options(
knitr.table.format = "html",
scipen = 999
)
library(dplyr)
library(knitr)
library(kableExtra)
tabla <- data.frame(
`Intervalo de x` = c("$x \\leq 0$",
"$0 < x < 1$",
"$1 \\leq x \\leq 2$",
"$2 < x < 4$",
"$x \\geq 4$",
"$\\Sigma$"),
`f(x)` = c("$0$",
"$\\frac{1}{3}$",
"$0$",
"$\\frac{1}{3}$",
"$0$",
"$1$"),
`F(x)` = c("$0$",
"$\\frac{x}{3}$",
"$\\frac{1}{3}$",
"$\\frac{x-1}{3}$",
"$1$",
"")
)
kable(
tabla,
align = "c",
caption = "Tabla de la función de densidad $f(x)$ y de la función de distribución acumulada $F(x)$ para la variable aleatoria $X$ del punto 8",
escape = FALSE
) %>%
kable_styling(
full_width = FALSE,
bootstrap_options = c("striped", "hover", "condensed")
) %>%
row_spec(0, bold = TRUE, color = "black", background = "#D9EAF7") %>%
row_spec(nrow(tabla), bold = TRUE, background = "#FADBD8") %>%
column_spec(1, bold = TRUE)
## Inciso d
ggplot(df_fx, aes(x = x, y = fx)) +
geom_point(shape = 15, size = 4, color = "#4C78A8") +
geom_segment(aes(xend = x, yend = 0), linewidth = 1, color = "#4C78A8") +
geom_text(aes(label = sprintf("%.2f", fx)), vjust = -0.6, size = 4) +
scale_x_continuous(breaks = 0:6, limits = c(-0.5, 6.5)) +
scale_y_continuous(limits = c(0, 0.32), breaks = seq(0, 0.30, 0.05)) +
labs(
title = "Función de probabilidad f(x)",
subtitle = "Distribución discreta del número de defectos importantes",
x = "Valores de X",
y = "f(x)"
) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5),
axis.title = element_text(face = "bold"),
panel.grid.minor = element_blank()
)
options(
knitr.table.format = "html",
scipen = 999
)
mu <- sum(x * fx)
df_e <- data.frame(
x = 0:6,
fx = c(0.06, 0.13, 0.20, 0.28, 0.25, 0.05, 0.03)
)
ggplot(df_e, aes(x = x, y = fx)) +
geom_point(shape = 15, size = 4, color = "#4C78A8") +
geom_segment(aes(xend = x, yend = 0), linewidth = 1, color = "#4C78A8") +
geom_text(aes(label = sprintf("%.2f", fx)), vjust = -0.9, size = 4) +
geom_vline(xintercept = mu, linetype = "dashed", color = "#E45756", linewidth = 1) +
annotate("text", x = mu + 0.25, y = 0.31, label = paste0("E(X) = ", round(mu, 2)),
color = "#E45756", hjust = 0, size = 4) +
scale_x_continuous(breaks = 0:6, limits = c(-0.5, 6.8)) +
scale_y_continuous(limits = c(0, 0.32), breaks = seq(0, 0.30, 0.05)) +
labs(
title = "Inciso e: Media de la distribución",
subtitle = "La línea punteada marca el valor esperado",
x = "Valores de X",
y = "f(x)"
) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5),
axis.title = element_text(face = "bold"),
panel.grid.minor = element_blank()
)
