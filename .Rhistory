ggplot(df, aes(x = x, y = Fx)) +
geom_line(linewidth = 1, color = "#E45756") +
geom_hline(yintercept = c(0.25, 0.75), linetype = "dashed", color = "#72B7B2") +
geom_vline(xintercept = c(0.75, 3.25), linetype = "dashed", color = "#4C78A8") +
geom_point(aes(x = 0.75, y = 0.25), color = "#4C78A8", size = 3) +
geom_point(aes(x = 3.25, y = 0.75), color = "#4C78A8", size = 3) +
annotate("text", x = 0.9, y = 0.15, label = "Q1 = 0.75", size = 4) +
annotate("text", x = 3.35, y = 0.66, label = "Q3 = 3.25", size = 4) +
labs(
title = "Inciso f: Cuartiles sobre F(x)",
subtitle = "Ubicación de Q1 y Q3",
x = "x",
y = "F(x)"
) +
scale_x_continuous(breaks = seq(0, 4, 0.5), limits = c(-0.5, 4.5)) +
scale_y_continuous(limits = c(0, 1.05), breaks = seq(0, 1, 0.1)) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5),
axis.title = element_text(face = "bold")
)
ipak <- function(pkg){
options(repos = c(CRAN="https://cloud.r-project.org"))
new.pkg <- pkg[!(pkg %in% rownames(installed.packages()))]
if(length(new.pkg)) install.packages(new.pkg, dependencies = TRUE)
invisible(lapply(pkg, function(p)
suppressPackageStartupMessages(library(p, character.only = TRUE))
))
}
packages <- c("tidyverse","kableExtra","knitr","dplyr","ggplot2","psych","readxl")
ipak(packages)
ggplot(df, aes(x = x, y = Fx)) +
geom_line(linewidth = 1, color = "#E45756") +
geom_hline(yintercept = c(0.25, 0.75), linetype = "dashed", color = "#72B7B2") +
geom_vline(xintercept = c(0.75, 3.25), linetype = "dashed", color = "#4C78A8") +
geom_point(aes(x = 0.75, y = 0.25), color = "#4C78A8", size = 3) +
geom_point(aes(x = 3.25, y = 0.75), color = "#4C78A8", size = 3) +
annotate("text", x = 0.9, y = 0.15, label = "Q1 = 0.75", size = 4) +
annotate("text", x = 3.35, y = 0.66, label = "Q3 = 3.25", size = 4) +
labs(
title = "Inciso f: Cuartiles sobre F(x)",
subtitle = "Ubicación de Q1 y Q3",
x = "x",
y = "F(x)"
) +
scale_x_continuous(breaks = seq(0, 4, 0.5), limits = c(-0.5, 4.5)) +
scale_y_continuous(limits = c(0, 1.05), breaks = seq(0, 1, 0.1)) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5),
axis.title = element_text(face = "bold")
)
x <- seq(-0.5, 4.5, by = 0.01)
Fx <- ifelse(x <= 0, 0,
ifelse(x > 0 & x < 1, x/3,
ifelse(x >= 1 & x <= 2, 1/3,
ifelse(x > 2 & x < 4, (x - 1)/3, 1))))
df_8 <- data.frame(x = x, Fx = Fx)
ggplot(df_8, aes(x = x, y = Fx)) +
geom_line(linewidth = 1, color = "#E45756") +
geom_hline(yintercept = c(0.25, 0.75), linetype = "dashed", color = "#72B7B2") +
geom_vline(xintercept = c(0.75, 3.25), linetype = "dashed", color = "#4C78A8") +
geom_point(aes(x = 0.75, y = 0.25), color = "#4C78A8", size = 3) +
geom_point(aes(x = 3.25, y = 0.75), color = "#4C78A8", size = 3) +
annotate("text", x = 0.9, y = 0.15, label = "Q1 = 0.75", size = 4) +
annotate("text", x = 3.35, y = 0.66, label = "Q3 = 3.25", size = 4) +
labs(
title = "Inciso f: Cuartiles sobre F(x)",
subtitle = "Ubicación de Q1 y Q3",
x = "x",
y = "F(x)"
) +
scale_x_continuous(breaks = seq(0, 4, 0.5), limits = c(-0.5, 4.5)) +
scale_y_continuous(limits = c(0, 1.05), breaks = seq(0, 1, 0.1)) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5),
axis.title = element_text(face = "bold")
)
options(
knitr.table.format = "html",
scipen = 999
)
