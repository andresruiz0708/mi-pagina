## Función de probabilidad

```{r}
# Cargar librerías
library(ggplot2)
library(dplyr)

# Crear una secuencia de valores de x
x <- seq(-1, 3, by = 0.01)

# Definir la función por tramos
f_x <- ifelse(x >= 0 & x < 1, 1 - x,
       ifelse(x >= 1 & x <= 2, x - 1, 0))

# Crear data frame
df <- data.frame(x = x, f_x = f_x)

# Graficar
ggplot(df, aes(x = x, y = f_x)) +
  geom_line(size = 1) +
  geom_area(alpha = 0.2) +
  labs(
    title = "Función de densidad por tramos",
    x = "x",
    y = "f(x)"
  ) +
  theme_minimal()
```

## Función de distribución

```{r}
library(ggplot2)

# Valores de x
x <- seq(-1, 3, by = 0.01)

# Definir F(x)
F_x <- ifelse(x < 0, 0,
       ifelse(x >= 0 & x < 1, x - (x^2)/2,
       ifelse(x >= 1 & x <= 2, (x^2)/2 - x + 1, 1)))

# Data frame
df <- data.frame(x = x, F_x = F_x)

# Gráfica
ggplot(df, aes(x = x, y = F_x)) +
  geom_line(size = 1) +
  labs(
    title = "Función de Distribución Acumulada (FDA)",
    x = "x",
    y = "F(x)"
  ) +
  theme_minimal()
```
