                          df <- data.frame(x = k, fx = fx)
                          
                          # Gráfica estilo profesor
                          plot(x = df$x, y = df$fx,
                               xlab = "Número de personas con menos de 25 p.p.m.",
                               ylab = "Probabilidad",
                               main = "Distribución Binomial",
                               pch = 19,
                               col = "#b349f5",
                               ylim = c(0, max(df$fx) + 0.01))
                          
                          # Segmentos verticales
                          segments(x0 = df$x, y0 = 0, x1 = df$x, y1 = df$fx,
                                   lwd = 2, col = "#02b8fa")
                          
                          # Resaltar intervalo 15 a 20
                          idx <- df$x >= 15 & df$x <= 20
                          
                          points(df$x[idx], df$fx[idx], pch = 19, col = "#E45756")
                          
                          segments(x0 = df$x[idx], y0 = 0,
                                   x1 = df$x[idx], y1 = df$fx[idx],
                                   lwd = 2, col = "#E45756")
                          
